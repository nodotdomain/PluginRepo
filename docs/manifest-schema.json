{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SpectreLens Plugin Manifest",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "description",
    "minAppVersion",
    "entrypoint"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "name": { "type": "string" },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": { "type": "string" },
    "author": { "type": "string" },
    "minAppVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "entrypoint": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "changelog": { "type": "string" },
    "homepage": { "type": "string", "format": "uri" }
  }
}
